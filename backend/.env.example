# Copy this file to .env and fill keys as available.

TAVILY_API_KEY=
NEWSAPI_KEY=
NEWSDATA_API_KEY=
GNEWS_API_KEY=
TAVILY_RECENT_DAYS=3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Local AI fallback (used when Gemini is unavailable or not configured)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# Comma separated origins, or * for local quick start.
CORS_ALLOW_ORIGINS=http://localhost:5173
REQUEST_TIMEOUT_SECONDS=15

# Multi-source RSS list (Times of India, NDTV, Indian Express, The Hindu, BBC India, Hindustan Times, Google News)
RSS_FEEDS=https://timesofindia.indiatimes.com/rssfeeds/-2128936835.cms,https://feeds.feedburner.com/ndtvnews-top-stories,https://indianexpress.com/section/india/feed/,https://www.thehindu.com/news/national/feeder/default.rss,https://feeds.bbci.co.uk/news/world/asia/india/rss.xml,https://www.hindustantimes.com/feeds/rss/india-news/rssfeed.xml,https://news.google.com/rss/search?q=india+law+and+order&hl=en-IN&gl=IN&ceid=IN:en

# Optional comma-separated website targets for HTML scraping
# WEB_SCRAPER_URLS=https://www.thehindu.com/news/national/,https://timesofindia.indiatimes.com/india
